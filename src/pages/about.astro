---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { PAGES } from "../config";

if (PAGES.about.isActive === false) {
    return Astro.redirect("/404");
}

const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
    ? await render(bioEntry)
    : { Content: null };
---

<BaseLayout title={PAGES.about.title}>
    <div class="container-narrow">
        <header class="page-header">
            <h1 class="page-title">{PAGES.about.title}</h1>
            {PAGES.about.subtitle && (
                <p class="page-subtitle">{PAGES.about.subtitle}</p>
            )}
        </header>
        <div class="prose">
            {BioContent ? <BioContent /> : <p>Bio içeriği bulunamadı.</p>}
        </div>
    </div>
</BaseLayout>
